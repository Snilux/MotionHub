---
import Title from "../components/common/Title.astro";
import Layout from "../layouts/Layout.astro";
import Icon from "../components/common/Icons.astro";
import AnimationBgAuth from "../components/common/AnimationBgAuth.astro";
---

<Layout title="Iniciar Sesión">
    <div
        class="relative min-h-screen flex items-center justify-center p-4 overflow-hidden"
    >
        <!-- Background Animation -->
        <div class="absolute inset-0 -z-10">
            <AnimationBgAuth />
        </div>

        <!-- Content -->
        <div class="w-full max-w-md relative z-10">
            <!-- Logo -->
            <div class="text-center mb-4">
                <div class="flex items-center justify-center gap-2 mb-2">
                    <a href="/">
                        <Title size="lg" />
                    </a>
                </div>
            </div>

            <!-- Glass Card -->
            <div
                class="backdrop-blur-xl bg-white/50 rounded-3xl shadow-2xl p-8"
            >
                <div class="mb-8">
                    <h2 class="text-3xl font-medium mb-2">
                        Bienvenido de vuelta
                    </h2>
                    <p class="font-light opacity-80">
                        Ingresa tus credenciales para continuar
                    </p>
                </div>

                <div id="loginError" class="hidden text-sm text-red-600 bg-red-50 px-3 py-2 rounded-xl mb-2"></div>
                <div id="loginInfo"  class="hidden text-sm text-amber-700 bg-amber-50 px-3 py-2 rounded-xl mb-2"></div>
                <form id="loginForm" class="space-y-6">
                    <!-- Email Input -->
                    <div>
                        <label
                            for="email"
                            class="block text-sm font-medium text-gray-700 mb-2"
                        >
                            Correo electrónico
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="tu@email.com"
                            class="w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 placeholder:text-gray-400"
                        />
                    </div>

                    <!-- Password Input -->
                    <div>
                        <label
                            for="password"
                            class="block text-sm font-medium text-gray-700 mb-2"
                        >
                            Contraseña
                        </label>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            required
                            placeholder="••••••••"
                            class="w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 placeholder:text-gray-400"
                        />
                    </div>

                    <!-- Remember & Forgot -->
                    <div class="flex items-center justify-between">
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
                            />
                            <span class="ml-2 text-sm text-gray-600"
                                >Recordarme</span
                            >
                        </label>
                        <a
                            href="/reset-password"
                            class="text-sm text-blue-600 hover:text-blue-700 font-medium"
                        >
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                    <!-- Submit Button -->
                    <button
                        type="submit"
                        class="w-full bg-linear-to-r from-blue-600 to-blue-500 text-white py-3 px-4 rounded-xl font-semibold hover:from-blue-700 hover:to-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200 shadow-lg shadow-blue-500/30"
                    >
                        Iniciar sesión
                    </button>

                    <!-- Divider -->
                    <div class="relative my-6">
                        <div class="relative flex justify-center text-sm">
                            <span class="px-4">O continúa con</span>
                        </div>
                    </div>

                    <!-- Social Login -->
                    <div class="flex justify-center gap-4">
                        <button
                            type="button"
                            class="flex items-center justify-center gap-2 px-4 py-3 bg-white/50 border border-gray-200 rounded-xl hover:bg-white/80 transition-all duration-200 w-full shadow-2xl"
                        >
                            <Icon name="google" />
                            <span class="text-sm font-medium text-gray-700"
                                >Google</span
                            >
                        </button>
                    </div>
                </form>

                <!-- Register Link -->
                <div class="mt-4 text-center">
                    <p class="text-gray-600">
                        ¿No tienes una cuenta?
                        <a
                            href="/register"
                            class="text-blue-600 hover:text-blue-700 font-semibold"
                        >
                            Regístrate aquí
                        </a>
                    </p>
                </div>
            </div>

            <!-- Footer -->
            <div class="mt-6 text-center text-sm text-gray-500">
                <p>© 2024 MotionHub. Todos los derechos reservados.</p>
            </div>
        </div>
    </div>
</Layout>

<script>
  // Mostrar mensaje si fue redirigido por expiración o sesión duplicada
  const razon = new URLSearchParams(window.location.search).get("razon");
  const info  = document.getElementById("loginInfo");
  if (info) {
    if (razon === "expiracion") {
      info.textContent = "⏱️ Tu sesión expiró por inactividad. Inicia sesión nuevamente.";
      info.classList.remove("hidden");
    } else if (razon === "sesion_duplicada") {
      info.textContent = "⚠️ Tu sesión fue cerrada porque iniciaste sesión desde otro dispositivo.";
      info.classList.remove("hidden");
    }
  }

  document.getElementById("loginForm")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (document.getElementById("email") as HTMLInputElement).value;
    const password = (document.getElementById("password") as HTMLInputElement).value;
    const errorEl = document.getElementById("loginError")!;
    const btn = e.submitter as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = "Iniciando sesión..."; }

    const res = await fetch("/api/auth/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password }),
    });
    const data = await res.json();

    if (res.ok) {
      window.location.href = data.redirect;
    } else {
      errorEl.textContent = data.error || "Error al iniciar sesión";
      errorEl.classList.remove("hidden");
      if (btn) { btn.disabled = false; btn.textContent = "Iniciar sesión"; }
    }
  });
</script>