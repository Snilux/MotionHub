---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import connectDB from "../../../lib/db";
import { User } from "../../../models/User";
import { Cita } from "../../../models/Cita";
import { getSessionFromRequest } from "../../../lib/session";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") {
  return Astro.redirect("/login");
}

await connectDB();

const hoy = new Date();
const manana = new Date(hoy);
manana.setDate(manana.getDate() + 1);

const [totalPacientes, citasHoy, citasPendientes] = await Promise.all([
  User.countDocuments({ role: "paciente", medicoAsignado: session.userId }),
  Cita.countDocuments({
    medico: session.userId,
    fecha: { $gte: hoy, $lt: manana },
    estado: { $ne: "cancelada" },
  }),
  Cita.countDocuments({
    medico: session.userId,
    estado: "pendiente",
    fecha: { $gte: hoy },
  }),
]);

const proximasCitas = await Cita.find({
  medico: session.userId,
  fecha: { $gte: hoy },
  estado: { $in: ["pendiente", "confirmada"] },
})
  .populate("paciente", "nombre apellido")
  .sort({ fecha: 1 })
  .limit(5);
---

<DashboardLayout
  title="Dashboard Médico"
  role="medico"
  nombre={session.nombre}
  activeSection="/dashboard/medico"
>
  <div class="p-6 lg:p-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">
        Bienvenido, Dr. {session.nombre} 👋
      </h1>
      <p class="text-gray-500 mt-1">
        {hoy.toLocaleDateString("es-MX", { weekday: "long", year: "numeric", month: "long", day: "numeric" })}
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Mis Pacientes</span>
          <span class="text-2xl">👥</span>
        </div>
        <p class="text-3xl font-bold text-gray-900">{totalPacientes}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Citas Hoy</span>
          <span class="text-2xl">📅</span>
        </div>
        <p class="text-3xl font-bold text-blue-600">{citasHoy}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Citas Pendientes</span>
          <span class="text-2xl">⏳</span>
        </div>
        <p class="text-3xl font-bold text-amber-500">{citasPendientes}</p>
      </div>
    </div>

    <!-- Próximas citas -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-semibold text-gray-900">Próximas Citas</h2>
        <a
          href="/dashboard/medico/citas"
          class="text-sm text-blue-600 hover:text-blue-700 font-medium"
        >
          Ver todas →
        </a>
      </div>

      {
        proximasCitas.length === 0 ? (
          <div class="text-center py-10 text-gray-400">
            <p class="text-4xl mb-2">🗓️</p>
            <p>No tienes citas próximas</p>
          </div>
        ) : (
          <div class="space-y-3">
            {proximasCitas.map((cita: any) => (
              <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 hover:bg-gray-100 transition-colors">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-semibold">
                    {cita.paciente.nombre.charAt(0)}
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">
                      {cita.paciente.nombre} {cita.paciente.apellido}
                    </p>
                    <p class="text-sm text-gray-500 capitalize">{cita.tipo}</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm font-medium text-gray-700">
                    {new Date(cita.fecha).toLocaleDateString("es-MX", { day: "numeric", month: "short" })}
                  </p>
                  <p class="text-xs text-gray-400">
                    {new Date(cita.fecha).toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" })}
                  </p>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>

    <!-- Accesos rápidos -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6">
      {[
        { href: "/dashboard/medico/pacientes", label: "Agregar Paciente", icon: "➕" },
        { href: "/dashboard/medico/citas", label: "Nueva Cita", icon: "📅" },
        { href: "/dashboard/medico/rutinas", label: "Nueva Rutina", icon: "🏋️" },
        { href: "/dashboard/medico/expedientes", label: "Expedientes", icon: "📋" },
      ].map((item) => (
        <a
          href={item.href}
          class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-shadow text-center group"
        >
          <div class="text-3xl mb-2">{item.icon}</div>
          <p class="text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors">
            {item.label}
          </p>
        </a>
      ))}
    </div>
  </div>
</DashboardLayout>
