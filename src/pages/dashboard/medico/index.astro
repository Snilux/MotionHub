---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import connectDB from "../../../lib/db";
import { User } from "../../../models/User";
import { Cita } from "../../../models/Cita";
import { getSessionFromRequest } from "../../../lib/session";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") return Astro.redirect("/login");

await connectDB();

const hoy = new Date();
const manana = new Date(hoy);
manana.setDate(manana.getDate() + 1);

const [totalPacientes, citasHoy, citasPendientes] = await Promise.all([
  User.countDocuments({ role: "paciente", medicoAsignado: session.userId }),
  Cita.countDocuments({ medico: session.userId, fecha: { $gte: hoy, $lt: manana }, estado: { $ne: "cancelada" } }),
  Cita.countDocuments({ medico: session.userId, estado: "pendiente", fecha: { $gte: hoy } }),
]);

const proximasCitas = await Cita.find({
  medico: session.userId,
  fecha: { $gte: hoy },
  estado: { $in: ["pendiente", "confirmada"] },
})
  .populate("paciente", "nombre apellido")
  .sort({ fecha: 1 })
  .limit(5);

const diasSemana = ["Dom","Lun","Mar","Mié","Jue","Vie","Sáb"];
const meses = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"];
---

<DashboardLayout title="Dashboard" role="medico" nombre={session.nombre} activeSection="/dashboard/medico">

  <!-- Top bar -->
  <div class="border-b border-gray-200 px-8 py-4 flex items-center justify-between">
    <div>
      <p class="text-xs text-gray-400 font-light tracking-widest uppercase">
        {diasSemana[hoy.getDay()]}, {hoy.getDate()} {meses[hoy.getMonth()]} {hoy.getFullYear()}
      </p>
      <h1 class="text-xl font-baloo tracking-wide mt-0.5">
        Bienvenido, Dr. <strong>{session.nombre}</strong>
      </h1>
    </div>
    <a href="/dashboard/medico/citas"
      class="text-xs border border-black px-4 py-2 rounded-lg hover:bg-black hover:text-white transition-colors duration-200 tracking-wide font-light">
      + Nueva cita
    </a>
  </div>

  <div class="px-8 py-6 space-y-8">

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-4">
      {[
        { label: "Pacientes",        value: totalPacientes, sub: "asignados" },
        { label: "Citas hoy",        value: citasHoy,       sub: "programadas" },
        { label: "Por confirmar",    value: citasPendientes, sub: "pendientes" },
      ].map(({ label, value, sub }) => (
        <div class="border border-gray-200 rounded-lg p-5">
          <p class="text-xs text-gray-400 font-light tracking-widest uppercase mb-3">{label}</p>
          <p class="text-4xl font-baloo font-bold">{value}</p>
          <p class="text-xs text-gray-400 font-light mt-1">{sub}</p>
        </div>
      ))}
    </div>

    <!-- Two columns -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

      <!-- Próximas citas (wider) -->
      <div class="lg:col-span-3 border border-gray-200 rounded-lg">
        <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-sm font-medium tracking-wide">Próximas citas</h2>
          <a href="/dashboard/medico/citas" class="text-xs text-gray-400 hover:text-gray-700 font-light">Ver todas →</a>
        </div>

        {proximasCitas.length === 0 ? (
          <div class="px-5 py-12 text-center">
            <p class="text-gray-300 text-3xl mb-2">—</p>
            <p class="text-sm text-gray-400 font-light">Sin citas próximas</p>
          </div>
        ) : (
          <div class="divide-y divide-gray-100">
            {proximasCitas.map((c: any) => {
              const fecha = new Date(c.fecha);
              return (
                <div class="px-5 py-3.5 flex items-center justify-between hover:bg-gray-50 transition-colors">
                  <div class="flex items-center gap-4">
                    <!-- Mini fecha -->
                    <div class="w-10 text-center shrink-0">
                      <p class="text-xs text-gray-400 font-light uppercase">{meses[fecha.getMonth()]}</p>
                      <p class="text-lg font-baloo font-bold leading-tight">{fecha.getDate()}</p>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900">{c.paciente.nombre} {c.paciente.apellido}</p>
                      <p class="text-xs text-gray-400 font-light capitalize">{c.tipo} · {fecha.toLocaleTimeString("es-MX",{hour:"2-digit",minute:"2-digit"})}</p>
                    </div>
                  </div>
                  <span class={`text-xs px-2.5 py-1 rounded-full font-light
                    ${c.estado==="confirmada" ? "bg-black text-white" : "border border-gray-300 text-gray-500"}`}>
                    {c.estado}
                  </span>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- Accesos rápidos -->
      <div class="lg:col-span-2 space-y-3">
        <h2 class="text-sm font-medium tracking-wide px-0.5">Accesos rápidos</h2>
        {[
          { href: "/dashboard/medico/pacientes",   label: "Agregar paciente",   desc: "Asigna un nuevo paciente" },
          { href: "/dashboard/medico/rutinas",      label: "Crear rutina",        desc: "Diseña un programa de ejercicio" },
          { href: "/dashboard/medico/expedientes",  label: "Ver expedientes",     desc: "Historial clínico completo" },
        ].map(({ href, label, desc }) => (
          <a href={href}
            class="block border border-gray-200 rounded-lg px-4 py-3.5 hover:border-black hover:shadow-sm transition-all duration-200 group">
            <p class="text-sm font-medium group-hover:text-black">{label}</p>
            <p class="text-xs text-gray-400 font-light mt-0.5">{desc}</p>
          </a>
        ))}
      </div>

    </div>
  </div>
</DashboardLayout>