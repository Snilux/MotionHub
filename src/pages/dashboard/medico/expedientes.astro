---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Expediente } from "../../../models/Expediente";
import { User } from "../../../models/User";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") return Astro.redirect("/login");

await connectDB();

const pacienteId = Astro.url.searchParams.get("paciente");
const [expedientes, pacientes] = await Promise.all([
  Expediente.find({ medico: session.userId })
    .populate("paciente","nombre apellido email fechaNacimiento")
    .sort({ updatedAt: -1 }),
  User.find({ role:"paciente", medicoAsignado: session.userId }).select("_id nombre apellido"),
]);

const expedienteSeleccionado = pacienteId
  ? expedientes.find((e: any) => e.paciente._id.toString() === pacienteId)
  : null;

const meses = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"];
---

<DashboardLayout title="Expedientes" role="medico" nombre={session.nombre} activeSection="/dashboard/medico/expedientes">

  <div class="border-b border-gray-200 px-8 py-4 flex items-center justify-between">
    <div>
      <p class="text-xs text-gray-400 font-light tracking-widest uppercase">Clínico</p>
      <h1 class="text-xl font-baloo tracking-wide mt-0.5"><strong>Expedientes</strong></h1>
    </div>
    <button id="nuevoExpBtn"
      class="text-xs border border-black px-4 py-2 rounded-lg hover:bg-black hover:text-white transition-colors duration-200 tracking-wide font-light">
      + Nuevo expediente
    </button>
  </div>

  <div class="flex h-[calc(100vh-65px)]">

    <!-- Lista lateral -->
    <div class="w-64 border-r border-gray-200 flex flex-col shrink-0 overflow-y-auto">
      <div class="px-4 py-3 border-b border-gray-100">
        <p class="text-xs text-gray-400 font-light tracking-wide">{expedientes.length} expediente{expedientes.length!==1?"s":""}</p>
      </div>
      {expedientes.length === 0 ? (
        <div class="px-4 py-8 text-center">
          <p class="text-xs text-gray-400 font-light">Sin expedientes</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-100">
          {expedientes.map((e: any) => (
            <a href={`/dashboard/medico/expedientes?paciente=${e.paciente._id}`}
              class={`block px-4 py-3.5 hover:bg-gray-50 transition-colors
                ${pacienteId===e.paciente._id.toString() ? "bg-gray-50 border-l-2 border-black" : ""}`}>
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center text-white text-xs font-baloo font-bold shrink-0">
                  {e.paciente.nombre.charAt(0)}
                </div>
                <div class="min-w-0">
                  <p class="text-xs font-medium text-gray-900 truncate">{e.paciente.nombre} {e.paciente.apellido}</p>
                  <p class="text-xs text-gray-400 font-light truncate">{e.diagnostico}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Detalle -->
    <div class="flex-1 overflow-y-auto">
      {!expedienteSeleccionado ? (
        <div class="flex items-center justify-center h-full">
          <div class="text-center">
            <p class="text-5xl font-baloo text-gray-200 mb-3">—</p>
            <p class="text-sm text-gray-400 font-light">Selecciona un expediente</p>
          </div>
        </div>
      ) : (
        <div class="px-8 py-6 space-y-6 max-w-2xl">

          <!-- Header paciente -->
          <div class="flex items-start justify-between pb-5 border-b border-gray-200">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-black flex items-center justify-center text-white font-baloo font-bold">
                {(expedienteSeleccionado as any).paciente.nombre.charAt(0)}
              </div>
              <div>
                <h2 class="font-baloo tracking-wide text-lg">
                  <strong>{(expedienteSeleccionado as any).paciente.nombre} {(expedienteSeleccionado as any).paciente.apellido}</strong>
                </h2>
                <p class="text-xs text-gray-400 font-light">{(expedienteSeleccionado as any).paciente.email}</p>
              </div>
            </div>
            <p class="text-xs text-gray-400 font-light">
              Actualizado: {new Date((expedienteSeleccionado as any).updatedAt).getDate()} {meses[new Date((expedienteSeleccionado as any).updatedAt).getMonth()]}
            </p>
          </div>

          <!-- Datos clínicos -->
          <div class="grid grid-cols-2 gap-4">
            {[
              { label:"Diagnóstico",       value:(expedienteSeleccionado as any).diagnostico },
              { label:"Motivo de consulta", value:(expedienteSeleccionado as any).motivoConsulta },
              { label:"Antecedentes",      value:(expedienteSeleccionado as any).antecedentes },
              { label:"Alergias",          value:(expedienteSeleccionado as any).alergias },
              { label:"Medicamentos",      value:(expedienteSeleccionado as any).medicamentos },
              { label:"Presión arterial",  value:(expedienteSeleccionado as any).presionArterial },
            ].map(({label,value}) => value ? (
              <div>
                <p class="text-xs text-gray-400 font-light uppercase tracking-widest mb-1">{label}</p>
                <p class="text-sm font-light text-gray-800 border border-gray-200 rounded-lg px-3 py-2">{value}</p>
              </div>
            ) : null)}
          </div>

          <!-- Datos físicos -->
          {((expedienteSeleccionado as any).altura || (expedienteSeleccionado as any).peso) && (
            <div class="flex gap-3">
              {(expedienteSeleccionado as any).altura && (
                <div class="border border-gray-200 rounded-lg px-5 py-3 text-center">
                  <p class="text-xs text-gray-400 font-light uppercase tracking-wide">Altura</p>
                  <p class="text-xl font-baloo font-bold mt-0.5">{(expedienteSeleccionado as any).altura}<span class="text-xs font-light text-gray-400 ml-1">cm</span></p>
                </div>
              )}
              {(expedienteSeleccionado as any).peso && (
                <div class="border border-gray-200 rounded-lg px-5 py-3 text-center">
                  <p class="text-xs text-gray-400 font-light uppercase tracking-wide">Peso</p>
                  <p class="text-xl font-baloo font-bold mt-0.5">{(expedienteSeleccionado as any).peso}<span class="text-xs font-light text-gray-400 ml-1">kg</span></p>
                </div>
              )}
            </div>
          )}

          <!-- Notas evolución -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <p class="text-xs text-gray-500 font-light uppercase tracking-widest">Notas de evolución</p>
              <button id="agregarNotaBtn"
                class="text-xs border border-gray-300 px-2.5 py-1 rounded-lg hover:border-black transition-colors font-light">
                + Agregar nota
              </button>
            </div>
            <div id="notaForm" class="hidden mb-3 space-y-2">
              <textarea id="notaTexto" rows="3" placeholder="Nota de evolución..."
                class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors resize-none"></textarea>
              <button id="guardarNota" data-paciente={(expedienteSeleccionado as any).paciente._id}
                class="px-4 py-2 bg-black text-white rounded-lg text-sm font-light hover:bg-gray-800 transition-colors">
                Guardar nota
              </button>
            </div>
            <div class="space-y-3 max-h-72 overflow-y-auto">
              {(expedienteSeleccionado as any).evolucion?.length === 0 ? (
                <p class="text-xs text-gray-400 font-light py-4">Sin notas de evolución</p>
              ) : (
                [...(expedienteSeleccionado as any).evolucion].reverse().map((nota: any) => (
                  <div class="border-l border-gray-300 pl-4 py-1">
                    <p class="text-xs text-gray-400 font-light mb-1">
                      {new Date(nota.fecha).getDate()} {meses[new Date(nota.fecha).getMonth()]} {new Date(nota.fecha).getFullYear()}
                    </p>
                    <p class="text-sm font-light text-gray-700">{nota.nota}</p>
                  </div>
                ))
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Modal nuevo expediente -->
  <div id="modalExp" class="hidden fixed inset-0 z-50 bg-black/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg border border-gray-200 shadow-lg p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <h2 class="font-baloo tracking-wide text-base mb-1"><strong>Nuevo expediente</strong></h2>
      <p class="text-xs text-gray-400 font-light mb-5">Historial clínico del paciente</p>
      <div class="space-y-3">
        <div>
          <label class="text-xs text-gray-500 font-light block mb-1 uppercase tracking-wide">Paciente</label>
          <select id="expPaciente" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black">
            <option value="">Seleccionar...</option>
            {pacientes.map((p: any) => <option value={p._id}>{p.nombre} {p.apellido}</option>)}
          </select>
        </div>
        {[
          {id:"expDiagnostico", label:"Diagnóstico *"},
          {id:"expMotivo",      label:"Motivo de consulta *"},
          {id:"expAntecedentes",label:"Antecedentes"},
          {id:"expAlergias",    label:"Alergias"},
          {id:"expMedicamentos",label:"Medicamentos actuales"},
          {id:"expPresion",     label:"Presión arterial"},
        ].map(({id,label}) => (
          <div>
            <label class="text-xs text-gray-500 font-light block mb-1 uppercase tracking-wide">{label}</label>
            <input id={id} type="text"
              class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors" />
          </div>
        ))}
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-gray-500 font-light block mb-1 uppercase tracking-wide">Altura (cm)</label>
            <input id="expAltura" type="number" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-light block mb-1 uppercase tracking-wide">Peso (kg)</label>
            <input id="expPeso" type="number" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors" />
          </div>
        </div>
        <div id="expError" class="hidden text-xs text-gray-500 font-light"></div>
        <div class="flex gap-2 pt-1">
          <button id="cancelarExp" class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-light hover:border-gray-400 transition-colors">Cancelar</button>
          <button id="guardarExp"  class="flex-1 px-4 py-2.5 bg-black text-white rounded-lg text-sm font-light hover:bg-gray-800 transition-colors">Guardar</button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  document.getElementById("nuevoExpBtn")?.addEventListener("click", () => document.getElementById("modalExp")?.classList.remove("hidden"));
  document.getElementById("cancelarExp")?.addEventListener("click", () => document.getElementById("modalExp")?.classList.add("hidden"));
  document.getElementById("guardarExp")?.addEventListener("click", async () => {
    const paciente = (document.getElementById("expPaciente") as HTMLSelectElement).value;
    const diagnostico = (document.getElementById("expDiagnostico") as HTMLInputElement).value;
    const motivoConsulta = (document.getElementById("expMotivo") as HTMLInputElement).value;
    const errorEl = document.getElementById("expError")!;
    if (!paciente||!diagnostico||!motivoConsulta) { errorEl.textContent="Paciente, diagnóstico y motivo son requeridos"; errorEl.classList.remove("hidden"); return; }
    const res = await fetch("/api/medico/expediente",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({
      paciente,diagnostico,motivoConsulta,
      antecedentes:(document.getElementById("expAntecedentes") as HTMLInputElement).value,
      alergias:(document.getElementById("expAlergias") as HTMLInputElement).value,
      medicamentos:(document.getElementById("expMedicamentos") as HTMLInputElement).value,
      presionArterial:(document.getElementById("expPresion") as HTMLInputElement).value,
      altura:Number((document.getElementById("expAltura") as HTMLInputElement).value)||undefined,
      peso:Number((document.getElementById("expPeso") as HTMLInputElement).value)||undefined,
    })});
    if (res.ok) { window.location.href=`/dashboard/medico/expedientes?paciente=${paciente}`; }
    else { const d=await res.json(); errorEl.textContent=d.error||"Error"; errorEl.classList.remove("hidden"); }
  });
  document.getElementById("agregarNotaBtn")?.addEventListener("click", () => document.getElementById("notaForm")?.classList.toggle("hidden"));
  document.getElementById("guardarNota")?.addEventListener("click", async () => {
    const nota = (document.getElementById("notaTexto") as HTMLTextAreaElement).value;
    const pacienteId = document.getElementById("guardarNota")?.getAttribute("data-paciente");
    if (!nota.trim()) return;
    const res = await fetch("/api/medico/expediente",{method:"PUT",headers:{"Content-Type":"application/json"},body:JSON.stringify({pacienteId,notaEvolucion:nota})});
    if (res.ok) window.location.reload();
  });
</script>