---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Expediente } from "../../../models/Expediente";
import { User } from "../../../models/User";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") return Astro.redirect("/login");

await connectDB();

const pacienteId = Astro.url.searchParams.get("paciente");
const [expedientes, pacientes] = await Promise.all([
  Expediente.find({ medico: session.userId })
    .populate("paciente", "nombre apellido email fechaNacimiento")
    .sort({ updatedAt: -1 }),
  User.find({ role: "paciente", medicoAsignado: session.userId })
    .select("_id nombre apellido"),
]);

const expedienteSeleccionado = pacienteId
  ? expedientes.find((e: any) => e.paciente._id.toString() === pacienteId)
  : null;
---

<DashboardLayout
  title="Expedientes"
  role="medico"
  nombre={session.nombre}
  activeSection="/dashboard/medico/expedientes"
>
  <div class="p-6 lg:p-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Expedientes Clínicos</h1>
        <p class="text-gray-500 mt-1">{expedientes.length} expedientes</p>
      </div>
      <button
        id="nuevoExpBtn"
        class="bg-blue-600 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-blue-700 transition-colors"
      >
        ➕ Nuevo Expediente
      </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Lista de expedientes -->
      <div class="lg:col-span-1 space-y-3">
        {expedientes.length === 0 ? (
          <div class="bg-white rounded-2xl border border-gray-100 p-8 text-center text-gray-400">
            <p class="text-4xl mb-2">📋</p>
            <p class="text-sm">Sin expedientes aún</p>
          </div>
        ) : (
          expedientes.map((e: any) => (
            <a
              href={`/dashboard/medico/expedientes?paciente=${e.paciente._id}`}
              class={`block bg-white rounded-2xl border p-4 hover:shadow-md transition-all
                ${pacienteId === e.paciente._id.toString() ? "border-blue-400 shadow-md" : "border-gray-100"}`}
            >
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-semibold">
                  {e.paciente.nombre.charAt(0)}
                </div>
                <div>
                  <p class="font-medium text-gray-900 text-sm">{e.paciente.nombre} {e.paciente.apellido}</p>
                  <p class="text-xs text-gray-500 truncate max-w-[160px]">{e.diagnostico}</p>
                </div>
              </div>
            </a>
          ))
        )}
      </div>

      <!-- Detalle expediente -->
      <div class="lg:col-span-2">
        {!expedienteSeleccionado ? (
          <div class="bg-white rounded-2xl border border-gray-100 p-12 text-center text-gray-400">
            <p class="text-5xl mb-3">📋</p>
            <p class="font-medium">Selecciona un expediente</p>
          </div>
        ) : (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">
            <!-- Cabecera -->
            <div class="flex items-start justify-between border-b border-gray-100 pb-4">
              <div>
                <h2 class="text-lg font-bold text-gray-900">
                  {(expedienteSeleccionado as any).paciente.nombre} {(expedienteSeleccionado as any).paciente.apellido}
                </h2>
                <p class="text-sm text-gray-500">{(expedienteSeleccionado as any).paciente.email}</p>
              </div>
              <div class="text-right text-xs text-gray-400">
                <p>Actualizado: {new Date((expedienteSeleccionado as any).updatedAt).toLocaleDateString("es-MX")}</p>
              </div>
            </div>

            <!-- Datos -->
            <div class="grid grid-cols-2 gap-4">
              {[
                { label: "Diagnóstico", value: (expedienteSeleccionado as any).diagnostico },
                { label: "Motivo de Consulta", value: (expedienteSeleccionado as any).motivoConsulta },
                { label: "Antecedentes", value: (expedienteSeleccionado as any).antecedentes },
                { label: "Alergias", value: (expedienteSeleccionado as any).alergias },
                { label: "Medicamentos", value: (expedienteSeleccionado as any).medicamentos },
                { label: "Presión Arterial", value: (expedienteSeleccionado as any).presionArterial },
              ].map(({ label, value }) => value ? (
                <div class="col-span-2 sm:col-span-1">
                  <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">{label}</p>
                  <p class="text-sm text-gray-800 bg-gray-50 rounded-xl px-3 py-2">{value}</p>
                </div>
              ) : null)}
            </div>

            <!-- Datos físicos -->
            {((expedienteSeleccionado as any).altura || (expedienteSeleccionado as any).peso) && (
              <div class="flex gap-4">
                {(expedienteSeleccionado as any).altura && (
                  <div class="bg-blue-50 rounded-xl px-4 py-3 text-center">
                    <p class="text-xs text-gray-500">Altura</p>
                    <p class="font-bold text-blue-700">{(expedienteSeleccionado as any).altura} cm</p>
                  </div>
                )}
                {(expedienteSeleccionado as any).peso && (
                  <div class="bg-blue-50 rounded-xl px-4 py-3 text-center">
                    <p class="text-xs text-gray-500">Peso</p>
                    <p class="font-bold text-blue-700">{(expedienteSeleccionado as any).peso} kg</p>
                  </div>
                )}
              </div>
            )}

            <!-- Notas de evolución -->
            <div>
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-gray-800">Notas de Evolución</h3>
                <button id="agregarNotaBtn" class="text-xs text-blue-600 hover:text-blue-700 font-medium">
                  + Agregar nota
                </button>
              </div>
              <div id="notaForm" class="hidden mb-3">
                <textarea id="notaTexto" rows="3" placeholder="Nota de evolución..."
                  class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none mb-2"></textarea>
                <button id="guardarNota" data-paciente={(expedienteSeleccionado as any).paciente._id}
                  class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700">
                  Guardar nota
                </button>
              </div>
              <div class="space-y-3 max-h-64 overflow-y-auto">
                {(expedienteSeleccionado as any).evolucion?.length === 0 ? (
                  <p class="text-sm text-gray-400 text-center py-4">Sin notas de evolución</p>
                ) : (
                  [...(expedienteSeleccionado as any).evolucion].reverse().map((nota: any) => (
                    <div class="border-l-2 border-blue-200 pl-3 py-1">
                      <p class="text-xs text-gray-400 mb-1">{new Date(nota.fecha).toLocaleDateString("es-MX", { day: "numeric", month: "long", year: "numeric" })}</p>
                      <p class="text-sm text-gray-700">{nota.nota}</p>
                    </div>
                  ))
                )}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Modal nuevo expediente -->
  <div id="modalExp" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <h2 class="text-lg font-semibold mb-5">Nuevo Expediente</h2>
      <div class="space-y-3">
        <div>
          <label class="text-sm font-medium text-gray-700 block mb-1">Paciente</label>
          <select id="expPaciente" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Seleccionar...</option>
            {pacientes.map((p: any) => (
              <option value={p._id}>{p.nombre} {p.apellido}</option>
            ))}
          </select>
        </div>
        {[
          { id: "expDiagnostico", label: "Diagnóstico", required: true },
          { id: "expMotivo", label: "Motivo de consulta", required: true },
          { id: "expAntecedentes", label: "Antecedentes" },
          { id: "expAlergias", label: "Alergias" },
          { id: "expMedicamentos", label: "Medicamentos actuales" },
          { id: "expPresion", label: "Presión arterial" },
        ].map(({ id, label, required }) => (
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">{label}{required ? " *" : ""}</label>
            <input id={id} type="text"
              class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
        ))}
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">Altura (cm)</label>
            <input id="expAltura" type="number" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">Peso (kg)</label>
            <input id="expPeso" type="number" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
        </div>
        <div id="expError" class="hidden text-sm text-red-500"></div>
        <div class="flex gap-3 pt-2">
          <button id="cancelarExp" class="flex-1 px-4 py-2 border border-gray-200 rounded-xl text-sm font-medium hover:bg-gray-50">Cancelar</button>
          <button id="guardarExp" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700">Guardar</button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  document.getElementById("nuevoExpBtn")?.addEventListener("click", () => document.getElementById("modalExp")?.classList.remove("hidden"));
  document.getElementById("cancelarExp")?.addEventListener("click", () => document.getElementById("modalExp")?.classList.add("hidden"));

  document.getElementById("guardarExp")?.addEventListener("click", async () => {
    const paciente = (document.getElementById("expPaciente") as HTMLSelectElement).value;
    const diagnostico = (document.getElementById("expDiagnostico") as HTMLInputElement).value;
    const motivoConsulta = (document.getElementById("expMotivo") as HTMLInputElement).value;
    const errorEl = document.getElementById("expError")!;
    if (!paciente || !diagnostico || !motivoConsulta) {
      errorEl.textContent = "Paciente, diagnóstico y motivo son requeridos";
      errorEl.classList.remove("hidden");
      return;
    }
    const res = await fetch("/api/medico/expediente", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        paciente,
        diagnostico,
        motivoConsulta,
        antecedentes: (document.getElementById("expAntecedentes") as HTMLInputElement).value,
        alergias: (document.getElementById("expAlergias") as HTMLInputElement).value,
        medicamentos: (document.getElementById("expMedicamentos") as HTMLInputElement).value,
        presionArterial: (document.getElementById("expPresion") as HTMLInputElement).value,
        altura: Number((document.getElementById("expAltura") as HTMLInputElement).value) || undefined,
        peso: Number((document.getElementById("expPeso") as HTMLInputElement).value) || undefined,
      }),
    });
    if (res.ok) {
      window.location.href = `/dashboard/medico/expedientes?paciente=${paciente}`;
    } else {
      const data = await res.json();
      errorEl.textContent = data.error || "Error al guardar";
      errorEl.classList.remove("hidden");
    }
  });

  document.getElementById("agregarNotaBtn")?.addEventListener("click", () => {
    document.getElementById("notaForm")?.classList.toggle("hidden");
  });

  document.getElementById("guardarNota")?.addEventListener("click", async () => {
    const nota = (document.getElementById("notaTexto") as HTMLTextAreaElement).value;
    const pacienteId = document.getElementById("guardarNota")?.getAttribute("data-paciente");
    if (!nota.trim()) return;
    const res = await fetch("/api/medico/expediente", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pacienteId, notaEvolucion: nota }),
    });
    if (res.ok) window.location.reload();
  });
</script>
