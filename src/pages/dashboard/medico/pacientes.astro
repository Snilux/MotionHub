---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { User } from "../../../models/User";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") return Astro.redirect("/login");

await connectDB();
const pacientes = await User.find({
  role: "paciente",
  medicoAsignado: session.userId,
})
  .select("-password -resetPasswordToken -resetPasswordExpires")
  .sort({ createdAt: -1 });
---

<DashboardLayout
  title="Pacientes"
  role="medico"
  nombre={session.nombre}
  activeSection="/dashboard/medico/pacientes"
>
  <div class="p-6 lg:p-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Mis Pacientes</h1>
        <p class="text-gray-500 mt-1">{pacientes.length} pacientes registrados</p>
      </div>
      <button
        id="asignarBtn"
        class="bg-blue-600 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-blue-700 transition-colors flex items-center gap-2"
      >
        ➕ Asignar Paciente
      </button>
    </div>

    {
      pacientes.length === 0 ? (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center text-gray-400">
          <p class="text-5xl mb-3">👥</p>
          <p class="text-lg font-medium">No tienes pacientes aún</p>
          <p class="text-sm mt-1">Asigna pacientes para empezar a gestionar sus tratamientos</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {pacientes.map((p: any) => (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-semibold text-lg">
                  {p.nombre.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-gray-900">{p.nombre} {p.apellido}</p>
                  <p class="text-sm text-gray-500">{p.email}</p>
                </div>
              </div>
              {p.diagnostico && (
                <p class="text-xs text-gray-500 bg-gray-50 rounded-lg px-3 py-2 mb-3">
                  🏥 {p.diagnostico}
                </p>
              )}
              <div class="flex gap-2">
                <a
                  href={`/dashboard/medico/expedientes?paciente=${p._id}`}
                  class="flex-1 text-center text-xs py-2 px-3 rounded-lg bg-blue-50 text-blue-700 hover:bg-blue-100 font-medium transition-colors"
                >
                  Expediente
                </a>
                <a
                  href={`/dashboard/medico/rutinas?paciente=${p._id}`}
                  class="flex-1 text-center text-xs py-2 px-3 rounded-lg bg-gray-50 text-gray-700 hover:bg-gray-100 font-medium transition-colors"
                >
                  Rutinas
                </a>
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>

  <!-- Modal asignar paciente -->
  <div
    id="modalAsignar"
    class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4"
  >
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md">
      <h2 class="text-lg font-semibold mb-4">Asignar Paciente por Email</h2>
      <input
        id="emailBuscar"
        type="email"
        placeholder="correo@paciente.com"
        class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 mb-4"
      />
      <div id="resultadoBusqueda" class="mb-4 hidden">
        <div class="p-3 bg-gray-50 rounded-xl text-sm" id="pacienteInfo"></div>
      </div>
      <div id="errorBusqueda" class="hidden text-sm text-red-500 mb-3"></div>
      <div class="flex gap-3">
        <button
          id="cancelarModal"
          class="flex-1 px-4 py-2 border border-gray-200 rounded-xl text-sm font-medium hover:bg-gray-50"
        >
          Cancelar
        </button>
        <button
          id="buscarPacienteBtn"
          class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700"
        >
          Buscar
        </button>
        <button
          id="confirmarAsignar"
          class="hidden flex-1 px-4 py-2 bg-green-600 text-white rounded-xl text-sm font-medium hover:bg-green-700"
        >
          Asignar
        </button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  let pacienteEncontrado: any = null;

  document.getElementById("asignarBtn")?.addEventListener("click", () => {
    document.getElementById("modalAsignar")?.classList.remove("hidden");
  });

  document.getElementById("cancelarModal")?.addEventListener("click", () => {
    document.getElementById("modalAsignar")?.classList.add("hidden");
    pacienteEncontrado = null;
  });

  document.getElementById("buscarPacienteBtn")?.addEventListener("click", async () => {
    const email = (document.getElementById("emailBuscar") as HTMLInputElement)?.value;
    if (!email) return;

    const res = await fetch(`/api/medico/buscar-paciente?email=${encodeURIComponent(email)}`);
    const data = await res.json();
    const errorEl = document.getElementById("errorBusqueda")!;
    const resultadoEl = document.getElementById("resultadoBusqueda")!;
    const infoEl = document.getElementById("pacienteInfo")!;
    const confirmarBtn = document.getElementById("confirmarAsignar")!;

    if (!res.ok || !data) {
      errorEl.textContent = "Paciente no encontrado";
      errorEl.classList.remove("hidden");
      resultadoEl.classList.add("hidden");
      confirmarBtn.classList.add("hidden");
      return;
    }

    pacienteEncontrado = data;
    infoEl.textContent = `${data.nombre} ${data.apellido} — ${data.email}`;
    errorEl.classList.add("hidden");
    resultadoEl.classList.remove("hidden");
    confirmarBtn.classList.remove("hidden");
  });

  document.getElementById("confirmarAsignar")?.addEventListener("click", async () => {
    if (!pacienteEncontrado) return;
    const res = await fetch("/api/medico/pacientes", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pacienteId: pacienteEncontrado._id }),
    });
    if (res.ok) {
      window.location.reload();
    }
  });
</script>
