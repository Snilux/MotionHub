---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { User } from "../../../models/User";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "medico") return Astro.redirect("/login");

await connectDB();
const pacientes = await User.find({ role: "paciente", medicoAsignado: session.userId })
  .select("-password -resetPasswordToken -resetPasswordExpires")
  .sort({ createdAt: -1 });
---

<DashboardLayout title="Pacientes" role="medico" nombre={session.nombre} activeSection="/dashboard/medico/pacientes">

  <div class="border-b border-gray-200 px-8 py-4 flex items-center justify-between">
    <div>
      <p class="text-xs text-gray-400 font-light tracking-widest uppercase">Gestión</p>
      <h1 class="text-xl font-baloo tracking-wide mt-0.5"><strong>Mis Pacientes</strong></h1>
    </div>
    <button id="asignarBtn"
      class="text-xs border border-black px-4 py-2 rounded-lg hover:bg-black hover:text-white transition-colors duration-200 tracking-wide font-light">
      + Asignar paciente
    </button>
  </div>

  <div class="px-8 py-6">
    <p class="text-xs text-gray-400 font-light mb-5 tracking-wide">{pacientes.length} paciente{pacientes.length !== 1 ? "s" : ""} registrado{pacientes.length !== 1 ? "s" : ""}</p>

    {pacientes.length === 0 ? (
      <div class="border border-gray-200 rounded-lg py-16 text-center">
        <p class="text-4xl font-baloo text-gray-200 mb-2">—</p>
        <p class="text-sm text-gray-400 font-light">Sin pacientes asignados aún</p>
        <button id="asignarBtn2"
          class="mt-4 text-xs border border-black px-4 py-2 rounded-lg hover:bg-black hover:text-white transition-colors duration-200 font-light">
          Asignar primer paciente
        </button>
      </div>
    ) : (
      <div class="border border-gray-200 rounded-lg divide-y divide-gray-100 overflow-hidden">
        <!-- Header -->
        <div class="grid grid-cols-12 px-5 py-2.5 bg-gray-50">
          <p class="col-span-4 text-xs text-gray-400 font-light uppercase tracking-widest">Paciente</p>
          <p class="col-span-4 text-xs text-gray-400 font-light uppercase tracking-widest">Diagnóstico</p>
          <p class="col-span-2 text-xs text-gray-400 font-light uppercase tracking-widest">Teléfono</p>
          <p class="col-span-2 text-xs text-gray-400 font-light uppercase tracking-widest text-right">Acciones</p>
        </div>
        {pacientes.map((p: any) => (
          <div class="grid grid-cols-12 px-5 py-3.5 items-center hover:bg-gray-50 transition-colors">
            <div class="col-span-4 flex items-center gap-3">
              <div class="w-7 h-7 rounded-full bg-black flex items-center justify-center text-white text-xs font-baloo font-bold shrink-0">
                {p.nombre.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">{p.nombre} {p.apellido}</p>
                <p class="text-xs text-gray-400 font-light">{p.email}</p>
              </div>
            </div>
            <p class="col-span-4 text-xs text-gray-500 font-light pr-4 truncate">{p.diagnostico || "—"}</p>
            <p class="col-span-2 text-xs text-gray-500 font-light">{p.telefono || "—"}</p>
            <div class="col-span-2 flex justify-end gap-2">
              <a href={`/dashboard/medico/expedientes?paciente=${p._id}`}
                class="text-xs border border-gray-300 px-3 py-1.5 rounded-lg hover:border-black hover:text-black transition-colors font-light">
                Expediente
              </a>
              <a href={`/dashboard/medico/rutinas?paciente=${p._id}`}
                class="text-xs border border-gray-300 px-3 py-1.5 rounded-lg hover:border-black hover:text-black transition-colors font-light">
                Rutinas
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Modal asignar -->
  <div id="modalAsignar" class="hidden fixed inset-0 z-50 bg-black/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg border border-gray-200 shadow-lg p-6 w-full max-w-sm">
      <h2 class="font-baloo tracking-wide text-base mb-1"><strong>Asignar paciente</strong></h2>
      <p class="text-xs text-gray-400 font-light mb-5">Busca por correo electrónico</p>
      <input id="emailBuscar" type="email" placeholder="correo@paciente.com"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors mb-3" />
      <div id="resultadoBusqueda" class="hidden mb-3">
        <div class="p-3 border border-gray-200 rounded-lg text-sm font-light" id="pacienteInfo"></div>
      </div>
      <div id="errorBusqueda" class="hidden text-xs text-gray-500 font-light mb-3"></div>
      <div class="flex gap-2">
        <button id="cancelarModal"
          class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm font-light hover:border-gray-400 transition-colors">
          Cancelar
        </button>
        <button id="buscarPacienteBtn"
          class="flex-1 px-4 py-2 border border-black bg-black text-white rounded-lg text-sm font-light hover:bg-white hover:text-black transition-colors">
          Buscar
        </button>
        <button id="confirmarAsignar"
          class="hidden flex-1 px-4 py-2 bg-black text-white rounded-lg text-sm font-light hover:bg-gray-800 transition-colors">
          Asignar
        </button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  let pacienteEncontrado: any = null;
  const openModal = () => document.getElementById("modalAsignar")?.classList.remove("hidden");
  document.getElementById("asignarBtn")?.addEventListener("click", openModal);
  document.getElementById("asignarBtn2")?.addEventListener("click", openModal);
  document.getElementById("cancelarModal")?.addEventListener("click", () => {
    document.getElementById("modalAsignar")?.classList.add("hidden");
    pacienteEncontrado = null;
  });
  document.getElementById("buscarPacienteBtn")?.addEventListener("click", async () => {
    const email = (document.getElementById("emailBuscar") as HTMLInputElement)?.value;
    if (!email) return;
    const res = await fetch(`/api/medico/buscar-paciente?email=${encodeURIComponent(email)}`);
    const data = await res.json();
    const errorEl = document.getElementById("errorBusqueda")!;
    const resultadoEl = document.getElementById("resultadoBusqueda")!;
    const infoEl = document.getElementById("pacienteInfo")!;
    const confirmarBtn = document.getElementById("confirmarAsignar")!;
    if (!res.ok || !data) {
      errorEl.textContent = "No se encontró ningún paciente con ese correo.";
      errorEl.classList.remove("hidden");
      resultadoEl.classList.add("hidden");
      confirmarBtn.classList.add("hidden");
      return;
    }
    pacienteEncontrado = data;
    infoEl.textContent = `${data.nombre} ${data.apellido} — ${data.email}`;
    errorEl.classList.add("hidden");
    resultadoEl.classList.remove("hidden");
    confirmarBtn.classList.remove("hidden");
  });
  document.getElementById("confirmarAsignar")?.addEventListener("click", async () => {
    if (!pacienteEncontrado) return;
    const res = await fetch("/api/medico/pacientes", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ pacienteId: pacienteEncontrado._id }),
    });
    if (res.ok) window.location.reload();
  });
</script>