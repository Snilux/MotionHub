---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Rutina } from "../../../models/Rutina";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "paciente") return Astro.redirect("/login");

await connectDB();

const rutinas = await Rutina.find({ paciente: session.userId })
  .populate("medico","nombre apellido especialidad")
  .sort({ activa: -1, createdAt: -1 });
---

<DashboardLayout title="Mis Rutinas" role="paciente" nombre={session.nombre} activeSection="/dashboard/paciente/rutinas">

  <div class="border-b border-gray-200 px-8 py-4">
    <p class="text-xs text-gray-400 font-light tracking-widest uppercase">Programas</p>
    <h1 class="text-xl font-baloo tracking-wide mt-0.5">
      <strong>Mis Rutinas</strong>
      <span class="text-sm font-light text-gray-400 ml-2">{rutinas.filter((r:any)=>r.activa).length} activas</span>
    </h1>
  </div>

  <div class="px-8 py-6">
    {rutinas.length === 0 ? (
      <div class="border border-gray-200 rounded-lg py-16 text-center">
        <p class="text-4xl font-baloo text-gray-200 mb-2">—</p>
        <p class="text-sm text-gray-400 font-light">Aún no tienes rutinas asignadas</p>
        <p class="text-xs text-gray-400 font-light mt-1">Tu fisioterapeuta te asignará un programa personalizado</p>
      </div>
    ) : (
      <div class="space-y-4">
        {rutinas.map((r: any) => (
          <div class={`border rounded-lg overflow-hidden transition-opacity ${r.activa ? "border-gray-200" : "border-gray-100 opacity-60"}`}>

            <!-- Cabecera rutina -->
            <div class="px-5 py-4 flex items-start justify-between border-b border-gray-100">
              <div>
                <div class="flex items-center gap-2.5 mb-1">
                  <h2 class="text-sm font-medium text-gray-900">{r.nombre}</h2>
                  <span class={`text-xs px-2 py-0.5 rounded-full font-light
                    ${r.activa ? "bg-black text-white" : "border border-gray-200 text-gray-400"}`}>
                    {r.activa ? "Activa" : "Inactiva"}
                  </span>
                </div>
                <p class="text-xs text-gray-400 font-light">
                  Dr. {r.medico.nombre} {r.medico.apellido}
                  {r.medico.especialidad ? ` · ${r.medico.especialidad}` : ""}
                </p>
                {r.objetivo && <p class="text-xs text-gray-500 font-light mt-1">Objetivo: {r.objetivo}</p>}
              </div>
              <div class="text-right shrink-0 ml-4">
                <p class="text-xs text-gray-400 font-light">{r.frecuencia}</p>
                <p class="text-xs text-gray-400 font-light mt-0.5">{r.ejercicios.length} ejercicio{r.ejercicios.length!==1?"s":""}</p>
              </div>
            </div>

            <!-- Toggle ejercicios -->
            <div class="px-5 py-3">
              <button
                class="toggle-ejercicios text-xs text-gray-500 hover:text-gray-900 font-light flex items-center gap-1.5 transition-colors"
                data-target={`ej-${r._id}`}
              >
                <span class="arrow text-gray-300">▶</span>
                Ver ejercicios
              </button>

              <div id={`ej-${r._id}`} class="hidden mt-4 space-y-2">
                {r.ejercicios.map((ej: any, i: number) => (
                  <div class="border border-gray-100 rounded-lg p-4">
                    <div class="flex items-start justify-between mb-2">
                      <div>
                        <p class="text-xs text-gray-400 font-light uppercase tracking-wide mb-0.5">Ejercicio {i+1}</p>
                        <p class="text-sm font-medium text-gray-900">{ej.nombre}</p>
                      </div>
                      <div class="flex gap-2 shrink-0 ml-4">
                        {[
                          { val: ej.series,       lbl: "series" },
                          { val: ej.repeticiones, lbl: "reps" },
                          { val: ej.descanso,     lbl: "seg" },
                        ].map(({ val, lbl }) => (
                          <div class="border border-gray-200 rounded-lg px-2.5 py-1.5 text-center min-w-[42px]">
                            <p class="text-sm font-baloo font-bold leading-tight">{val}</p>
                            <p class="text-xs text-gray-400 font-light">{lbl}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                    {ej.descripcion && <p class="text-xs text-gray-500 font-light">{ej.descripcion}</p>}
                    {ej.notas && <p class="text-xs text-gray-400 font-light italic mt-1">{ej.notas}</p>}
                  </div>
                ))}

                {r.activa && (
                  <button
                    class="registrar-sesion w-full mt-2 py-2.5 border border-black rounded-lg text-sm font-light hover:bg-black hover:text-white transition-colors duration-200"
                    data-rutina={r._id}
                    data-total={r.ejercicios.length}
                  >
                    Registrar sesión completada
                  </button>
                )}
              </div>
            </div>

          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Modal registrar sesión -->
  <div id="modalSesion" class="hidden fixed inset-0 z-50 bg-black/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg border border-gray-200 shadow-lg p-6 w-full max-w-sm">
      <h2 class="font-baloo tracking-wide text-base mb-1"><strong>Registrar sesión</strong></h2>
      <p class="text-xs text-gray-400 font-light mb-5">Anota cómo te sentiste hoy</p>
      <div class="space-y-5">
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs text-gray-500 font-light uppercase tracking-wide">Dolor antes</label>
            <span id="dolorAntesVal" class="text-sm font-baloo font-bold">5</span>
          </div>
          <input id="dolorAntes" type="range" min="0" max="10" value="5"
            class="w-full accent-black" />
          <div class="flex justify-between text-xs text-gray-300 font-light mt-1">
            <span>Sin dolor</span><span>Máximo</span>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs text-gray-500 font-light uppercase tracking-wide">Dolor después</label>
            <span id="dolorDespuesVal" class="text-sm font-baloo font-bold">3</span>
          </div>
          <input id="dolorDespues" type="range" min="0" max="10" value="3"
            class="w-full accent-black" />
          <div class="flex justify-between text-xs text-gray-300 font-light mt-1">
            <span>Sin dolor</span><span>Máximo</span>
          </div>
        </div>
        <div>
          <label class="text-xs text-gray-500 font-light uppercase tracking-wide block mb-1">Notas (opcional)</label>
          <textarea id="notasSesion" rows="2" placeholder="¿Cómo te sentiste hoy?"
            class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-light focus:outline-none focus:border-black transition-colors resize-none"></textarea>
        </div>
        <div class="flex gap-2 pt-1">
          <button id="cancelarSesion"
            class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-light hover:border-gray-400 transition-colors">
            Cancelar
          </button>
          <button id="guardarSesion"
            class="flex-1 px-4 py-2.5 bg-black text-white rounded-lg text-sm font-light hover:bg-gray-800 transition-colors">
            Guardar
          </button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  // Acordeón
  document.querySelectorAll(".toggle-ejercicios").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target")!;
      const target   = document.getElementById(targetId)!;
      const arrow    = btn.querySelector(".arrow")!;
      target.classList.toggle("hidden");
      arrow.textContent = target.classList.contains("hidden") ? "▶" : "▼";
    });
  });

  // Sliders
  const sliderAntes   = document.getElementById("dolorAntes")   as HTMLInputElement;
  const sliderDespues = document.getElementById("dolorDespues") as HTMLInputElement;
  sliderAntes?.addEventListener("input",   () => { document.getElementById("dolorAntesVal")!.textContent   = sliderAntes.value; });
  sliderDespues?.addEventListener("input", () => { document.getElementById("dolorDespuesVal")!.textContent = sliderDespues.value; });

  // Registrar sesión
  let rutinaActual: string | null = null;
  let totalActual = 0;

  document.querySelectorAll(".registrar-sesion").forEach((btn) => {
    btn.addEventListener("click", () => {
      rutinaActual = btn.getAttribute("data-rutina");
      totalActual  = Number(btn.getAttribute("data-total")) || 0;
      document.getElementById("modalSesion")?.classList.remove("hidden");
    });
  });

  document.getElementById("cancelarSesion")?.addEventListener("click", () => {
    document.getElementById("modalSesion")?.classList.add("hidden");
  });

  document.getElementById("guardarSesion")?.addEventListener("click", async () => {
    const res = await fetch("/api/paciente/progreso", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        rutina:               rutinaActual,
        dolorAntes:           Number(sliderAntes.value),
        dolorDespues:         Number(sliderDespues.value),
        notasPaciente:        (document.getElementById("notasSesion") as HTMLTextAreaElement).value,
        completado:           true,
        totalEjercicios:      totalActual,
        ejerciciosCompletados: totalActual,
      }),
    });
    if (res.ok) {
      document.getElementById("modalSesion")?.classList.add("hidden");
      // Feedback visual sin alert
      const btn = document.getElementById("guardarSesion")!;
      btn.textContent = "¡Guardado!";
      setTimeout(() => { btn.textContent = "Guardar"; }, 2000);
    }
  });
</script>