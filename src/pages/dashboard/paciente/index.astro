---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Cita } from "../../../models/Cita";
import { Rutina } from "../../../models/Rutina";
import { Progreso } from "../../../models/Progreso";
import { User } from "../../../models/User";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "paciente") return Astro.redirect("/login");

await connectDB();

const hoy = new Date();
const manana = new Date(hoy);
manana.setDate(manana.getDate() + 1);

const paciente = await User.findById(session.userId)
  .populate("medicoAsignado", "nombre apellido especialidad");

const [proximaCita, rutinasActivas, sesionesEstaSemana] = await Promise.all([
  Cita.findOne({
    paciente: session.userId,
    fecha: { $gte: hoy },
    estado: { $in: ["pendiente", "confirmada"] },
  })
    .populate("medico", "nombre apellido especialidad")
    .sort({ fecha: 1 }),
  Rutina.countDocuments({ paciente: session.userId, activa: true }),
  Progreso.countDocuments({
    paciente: session.userId,
    fecha: { $gte: new Date(Date.now() - 7 * 24 * 3600 * 1000) },
  }),
]);
---

<DashboardLayout
  title="Mi Dashboard"
  role="paciente"
  nombre={session.nombre}
  activeSection="/dashboard/paciente"
>
  <div class="p-6 lg:p-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">
        Hola, {session.nombre} 👋
      </h1>
      <p class="text-gray-500 mt-1">
        {hoy.toLocaleDateString("es-MX", { weekday: "long", year: "numeric", month: "long", day: "numeric" })}
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Rutinas Activas</span>
          <span class="text-2xl">🏋️</span>
        </div>
        <p class="text-3xl font-bold text-gray-900">{rutinasActivas}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Sesiones Esta Semana</span>
          <span class="text-2xl">✅</span>
        </div>
        <p class="text-3xl font-bold text-green-600">{sesionesEstaSemana}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-3">
          <span class="text-gray-500 text-sm font-medium">Próxima Cita</span>
          <span class="text-2xl">📅</span>
        </div>
        {proximaCita ? (
          <p class="text-lg font-bold text-blue-600">
            {new Date((proximaCita as any).fecha).toLocaleDateString("es-MX", { day: "numeric", month: "short" })}
          </p>
        ) : (
          <p class="text-sm text-gray-400">Sin citas próximas</p>
        )}
      </div>
    </div>

    <!-- Médico asignado + próxima cita -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <!-- Médico -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Mi Fisioterapeuta</h2>
        {!(paciente as any)?.medicoAsignado ? (
          <div class="text-center py-6 text-gray-400">
            <p class="text-3xl mb-2">👨‍⚕️</p>
            <p class="text-sm">Aún no tienes un médico asignado</p>
          </div>
        ) : (
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-xl">
              {(paciente as any).medicoAsignado.nombre.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-gray-900">
                Dr. {(paciente as any).medicoAsignado.nombre} {(paciente as any).medicoAsignado.apellido}
              </p>
              <p class="text-sm text-gray-500">{(paciente as any).medicoAsignado.especialidad || "Fisioterapeuta"}</p>
            </div>
          </div>
        )}
      </div>

      <!-- Próxima cita -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Próxima Cita</h2>
        {!proximaCita ? (
          <div class="text-center py-6 text-gray-400">
            <p class="text-3xl mb-2">🗓️</p>
            <p class="text-sm">No hay citas programadas</p>
          </div>
        ) : (
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-blue-50 flex flex-col items-center justify-center">
                <span class="text-xs font-bold text-blue-700">
                  {new Date((proximaCita as any).fecha).toLocaleDateString("es-MX", { month: "short" }).toUpperCase()}
                </span>
                <span class="text-lg font-bold text-blue-700">
                  {new Date((proximaCita as any).fecha).getDate()}
                </span>
              </div>
              <div>
                <p class="font-medium text-gray-900 capitalize">{(proximaCita as any).tipo}</p>
                <p class="text-sm text-gray-500">
                  {new Date((proximaCita as any).fecha).toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" })}
                </p>
              </div>
            </div>
            <span class={`inline-block text-xs px-2 py-1 rounded-full font-medium
              ${(proximaCita as any).estado === "confirmada" ? "bg-green-50 text-green-700" : "bg-amber-50 text-amber-700"}`}>
              {(proximaCita as any).estado}
            </span>
          </div>
        )}
      </div>
    </div>

    <!-- Accesos rápidos -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        { href: "/dashboard/paciente/citas", label: "Ver mis citas", icon: "📅" },
        { href: "/dashboard/paciente/rutinas", label: "Mis rutinas", icon: "🏋️" },
        { href: "/dashboard/paciente/progreso", label: "Registrar progreso", icon: "📈" },
      ].map((item) => (
        <a
          href={item.href}
          class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-shadow text-center group"
        >
          <div class="text-3xl mb-2">{item.icon}</div>
          <p class="text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors">{item.label}</p>
        </a>
      ))}
    </div>
  </div>
</DashboardLayout>
