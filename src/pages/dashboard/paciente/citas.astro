---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Cita } from "../../../models/Cita";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "paciente") return Astro.redirect("/login");

await connectDB();

const hoy = new Date();
const citas = await Cita.find({ paciente: session.userId })
  .populate("medico","nombre apellido especialidad")
  .sort({ fecha: -1 });

const proximas = citas.filter((c: any) => new Date(c.fecha) >= hoy && c.estado !== "cancelada");
const pasadas  = citas.filter((c: any) => new Date(c.fecha) <  hoy || c.estado === "completada" || c.estado === "cancelada");

const meses = ["ene","feb","mar","abr","may","jun","jul","ago","sep","oct","nov","dic"];
const dias  = ["Dom","Lun","Mar","Mié","Jue","Vie","Sáb"];
---

<DashboardLayout title="Mis Citas" role="paciente" nombre={session.nombre} activeSection="/dashboard/paciente/citas">

  <div class="border-b border-gray-200 px-8 py-4">
    <p class="text-xs text-gray-400 font-light tracking-widest uppercase">Agenda</p>
    <h1 class="text-xl font-baloo tracking-wide mt-0.5"><strong>Mis Citas</strong></h1>
  </div>

  <div class="px-8 py-6 space-y-8">

    <!-- Próximas -->
    <div>
      <div class="flex items-center justify-between mb-4">
        <p class="text-xs text-gray-400 font-light tracking-widest uppercase">Próximas</p>
        <p class="text-xs text-gray-400 font-light">{proximas.length} cita{proximas.length !== 1 ? "s" : ""}</p>
      </div>

      {proximas.length === 0 ? (
        <div class="border border-gray-200 rounded-lg py-12 text-center">
          <p class="text-4xl font-baloo text-gray-200 mb-2">—</p>
          <p class="text-sm text-gray-400 font-light">No tienes citas próximas</p>
        </div>
      ) : (
        <div class="space-y-3">
          {proximas.map((c: any) => {
            const f = new Date(c.fecha);
            return (
              <div class="border border-gray-200 rounded-lg p-5 hover:border-gray-400 transition-colors">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-4">
                    <!-- Fecha visual -->
                    <div class="w-12 text-center border border-gray-200 rounded-lg py-2 px-2 shrink-0">
                      <p class="text-xs text-gray-400 font-light uppercase">{meses[f.getMonth()]}</p>
                      <p class="text-xl font-baloo font-bold leading-tight">{f.getDate()}</p>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900 capitalize">{c.tipo}</p>
                      <p class="text-xs text-gray-500 font-light">
                        Dr. {c.medico.nombre} {c.medico.apellido}
                        {c.medico.especialidad ? ` · ${c.medico.especialidad}` : ""}
                      </p>
                      <p class="text-xs text-gray-400 font-light mt-0.5">
                        {dias[f.getDay()]} {f.getDate()} {meses[f.getMonth()]}
                        · {f.toLocaleTimeString("es-MX",{hour:"2-digit",minute:"2-digit"})}
                        · {c.duracion} min
                      </p>
                    </div>
                  </div>
                  <span class={`text-xs px-2.5 py-1 rounded-full font-light shrink-0
                    ${c.estado === "confirmada" ? "bg-black text-white" : "border border-gray-300 text-gray-500"}`}>
                    {c.estado}
                  </span>
                </div>
                {c.notas && (
                  <p class="mt-3 text-xs text-gray-500 font-light border-t border-gray-100 pt-3">
                    {c.notas}
                  </p>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Historial -->
    {pasadas.length > 0 && (
      <div>
        <p class="text-xs text-gray-400 font-light tracking-widest uppercase mb-4">Historial</p>
        <div class="border border-gray-200 rounded-lg divide-y divide-gray-100 overflow-hidden">
          <div class="grid grid-cols-12 px-5 py-2.5 bg-gray-50">
            <p class="col-span-2 text-xs text-gray-400 font-light uppercase tracking-widest">Fecha</p>
            <p class="col-span-4 text-xs text-gray-400 font-light uppercase tracking-widest">Fisioterapeuta</p>
            <p class="col-span-3 text-xs text-gray-400 font-light uppercase tracking-widest">Tipo</p>
            <p class="col-span-3 text-xs text-gray-400 font-light uppercase tracking-widest text-right">Estado</p>
          </div>
          {pasadas.slice(0, 10).map((c: any) => {
            const f = new Date(c.fecha);
            return (
              <div class="grid grid-cols-12 px-5 py-3 items-center hover:bg-gray-50 transition-colors opacity-70">
                <p class="col-span-2 text-xs text-gray-500 font-light">
                  {f.getDate()} {meses[f.getMonth()]} {f.getFullYear()}
                </p>
                <p class="col-span-4 text-xs text-gray-600 font-light">Dr. {c.medico.nombre} {c.medico.apellido}</p>
                <p class="col-span-3 text-xs text-gray-500 font-light capitalize">{c.tipo}</p>
                <div class="col-span-3 flex justify-end">
                  <span class="text-xs border border-gray-200 text-gray-400 px-2.5 py-1 rounded-full font-light capitalize">
                    {c.estado}
                  </span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

  </div>
</DashboardLayout>