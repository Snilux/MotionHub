---
import DashboardLayout from "../../../components/common/DashboardLayout.astro";
import { getSessionFromRequest } from "../../../lib/session";
import connectDB from "../../../lib/db";
import { Progreso } from "../../../models/Progreso";

const session = getSessionFromRequest(Astro.request);
if (!session || session.role !== "paciente") return Astro.redirect("/login");

await connectDB();

const registros = await Progreso.find({ paciente: session.userId })
  .populate("rutina", "nombre")
  .sort({ fecha: -1 })
  .limit(30);

const totalSesiones = registros.length;
const sesionesCompletadas = registros.filter((r: any) => r.completado).length;
const promedioDolorAntes = registros.length
  ? Math.round(registros.reduce((s: number, r: any) => s + r.dolorAntes, 0) / registros.length * 10) / 10
  : 0;
const promedioDolorDespues = registros.length
  ? Math.round(registros.reduce((s: number, r: any) => s + r.dolorDespues, 0) / registros.length * 10) / 10
  : 0;

// Datos para gráfica (últimos 10)
const chartData = [...registros].reverse().slice(-10).map((r: any) => ({
  fecha: new Date(r.fecha).toLocaleDateString("es-MX", { day: "numeric", month: "short" }),
  antes: r.dolorAntes,
  despues: r.dolorDespues,
}));
---

<DashboardLayout
  title="Mi Progreso"
  role="paciente"
  nombre={session.nombre}
  activeSection="/dashboard/paciente/progreso"
>
  <div class="p-6 lg:p-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Mi Progreso</h1>
      <p class="text-gray-500 mt-1">Seguimiento de tu recuperación</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      {[
        { label: "Total Sesiones", value: totalSesiones, icon: "📊", color: "text-gray-900" },
        { label: "Completadas", value: sesionesCompletadas, icon: "✅", color: "text-green-600" },
        { label: "Dolor promedio antes", value: promedioDolorAntes, icon: "📈", color: "text-red-500" },
        { label: "Dolor promedio después", value: promedioDolorDespues, icon: "📉", color: "text-blue-600" },
      ].map(({ label, value, icon, color }) => (
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <span class="text-gray-500 text-xs font-medium">{label}</span>
            <span>{icon}</span>
          </div>
          <p class={`text-2xl font-bold ${color}`}>{value}</p>
        </div>
      ))}
    </div>

    <!-- Gráfica de dolor -->
    {chartData.length > 0 && (
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
        <h2 class="text-base font-semibold text-gray-900 mb-5">Evolución del Dolor</h2>
        <div class="overflow-x-auto">
          <canvas id="dolorChart" height="200"></canvas>
        </div>
        <div class="flex items-center gap-6 mt-4 text-xs text-gray-500">
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span> Antes de sesión</div>
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-blue-400 inline-block"></span> Después de sesión</div>
        </div>
        <script define:vars={{ chartData }}>
          setTimeout(() => {
            const ctx = document.getElementById("dolorChart");
            if (!ctx) return;
            const labels = chartData.map(d => d.fecha);
            const antes = chartData.map(d => d.antes);
            const despues = chartData.map(d => d.despues);

            // Simple SVG chart
            const canvas = ctx;
            const W = canvas.offsetWidth || 600;
            const H = 200;
            canvas.setAttribute("width", W);
            canvas.setAttribute("height", H);
            const ctx2d = canvas.getContext("2d");
            if (!ctx2d) return;

            const pad = 40;
            const w = W - pad * 2;
            const h = H - pad * 2;
            const n = labels.length;
            const step = n > 1 ? w / (n - 1) : w;

            ctx2d.clearRect(0, 0, W, H);

            // Grid
            for (let i = 0; i <= 10; i += 2) {
              const y = pad + h - (i / 10) * h;
              ctx2d.strokeStyle = "#f3f4f6";
              ctx2d.beginPath();
              ctx2d.moveTo(pad, y);
              ctx2d.lineTo(W - pad, y);
              ctx2d.stroke();
              ctx2d.fillStyle = "#9ca3af";
              ctx2d.font = "10px sans-serif";
              ctx2d.fillText(String(i), 4, y + 4);
            }

            // Draw lines
            function drawLine(data, color) {
              ctx2d.beginPath();
              ctx2d.strokeStyle = color;
              ctx2d.lineWidth = 2;
              data.forEach((v, i) => {
                const x = pad + i * step;
                const y = pad + h - (v / 10) * h;
                i === 0 ? ctx2d.moveTo(x, y) : ctx2d.lineTo(x, y);
              });
              ctx2d.stroke();

              data.forEach((v, i) => {
                const x = pad + i * step;
                const y = pad + h - (v / 10) * h;
                ctx2d.beginPath();
                ctx2d.arc(x, y, 4, 0, Math.PI * 2);
                ctx2d.fillStyle = color;
                ctx2d.fill();
              });
            }

            drawLine(antes, "#f87171");
            drawLine(despues, "#60a5fa");

            // Labels
            labels.forEach((label, i) => {
              const x = pad + i * step;
              ctx2d.fillStyle = "#9ca3af";
              ctx2d.font = "9px sans-serif";
              ctx2d.textAlign = "center";
              ctx2d.fillText(label, x, H - 8);
            });
          }, 100);
        </script>
      </div>
    )}

    <!-- Historial de sesiones -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
      <div class="p-5 border-b border-gray-100">
        <h2 class="text-base font-semibold text-gray-900">Historial de Sesiones</h2>
      </div>
      {registros.length === 0 ? (
        <div class="p-12 text-center text-gray-400">
          <p class="text-4xl mb-2">📊</p>
          <p class="text-sm">Aún no hay sesiones registradas</p>
          <p class="text-xs mt-1">Registra tu progreso desde "Mis Rutinas"</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-50">
          {registros.map((r: any) => (
            <div class="px-5 py-4 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900">
                  {(r.rutina as any)?.nombre || "Sesión libre"}
                </p>
                <p class="text-xs text-gray-400">
                  {new Date(r.fecha).toLocaleDateString("es-MX", { day: "numeric", month: "long", year: "numeric" })}
                </p>
                {r.notasPaciente && (
                  <p class="text-xs text-gray-500 mt-1 italic">"{r.notasPaciente}"</p>
                )}
              </div>
              <div class="flex items-center gap-4 text-xs">
                <div class="text-center">
                  <p class="font-bold text-red-400">{r.dolorAntes}</p>
                  <p class="text-gray-400">antes</p>
                </div>
                <span class="text-gray-300">→</span>
                <div class="text-center">
                  <p class={`font-bold ${r.dolorDespues < r.dolorAntes ? "text-green-500" : "text-red-400"}`}>
                    {r.dolorDespues}
                  </p>
                  <p class="text-gray-400">después</p>
                </div>
                {r.completado && <span class="text-green-500">✅</span>}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
